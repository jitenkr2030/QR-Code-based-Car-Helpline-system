// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Vehicle owners and users
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  password  String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  vehicles  Vehicle[]
  bookings  ServiceBooking[]
  qrOrders  QRCodeOrder[]
}

// Vehicle information
model Vehicle {
  id           String   @id @default(cuid())
  qrCode       String   @unique
  vin          String   @unique
  make         String
  model        String
  year         Int
  licensePlate String   @unique
  color        String?
  mileage      Int?
  
  // Insurance and ownership
  insuranceCompany   String?
  insurancePolicy    String?
  insuranceExpiry    DateTime?
  
  // Relations
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  
  // Service records
  serviceHistory ServiceRecord[]
  bookings      ServiceBooking[]
  qrCodes       QRCode[]
  qrOrders      QRCodeOrder[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// QR Code orders
model QRCodeOrder {
  id                  String   @id @default(cuid())
  orderId             String   @unique
  userId              String
  vehicleId           String
  qrType              String   // basic, premium, fleet
  quantity            Int      @default(1)
  basePrice           Float
  totalPrice          Float
  deliveryMethod      String   // pickup, home, office
  deliveryAddress     String
  paymentMethod       String   // upi, card, netbanking, cash
  status              String   @default("pending") // pending, paid, processing, shipped, delivered, cancelled
  trackingNumber      String?
  notes               String?
  specialInstructions String?
  orderDate           DateTime @default(now())
  shippedDate         DateTime?
  deliveredDate        DateTime?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  qrCodes     QRCode[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// QR Codes
model QRCode {
  id            String   @id @default(cuid())
  qrCode        String   @unique
  vehicleId     String
  orderId       String?
  status        String   @default("pending") // pending, generated, delivered
  generatedAt    DateTime @default(now())
  deliveredAt    DateTime?
  deliveryMethod String?
  trackingNumber String?
  
  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  order   QRCodeOrder? @relation(fields: [orderId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Service history for vehicles
model ServiceRecord {
  id          String   @id @default(cuid())
  type        String   // Oil Change, Tire Rotation, Brake Inspection, etc.
  description String?
  mileage     Int?
  cost        Decimal?
  performedBy String?
  notes       String?
  
  // Relations
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  
  serviceDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Garages and service centers
model Garage {
  id          String   @id @default(cuid())
  name        String
  address     String
  phone       String
  email       String?
  website     String?
  
  // Location
  latitude    Float
  longitude   Float
  
  // Services and availability
  services    String   // JSON string of services offered
  hours       String   // Business hours
  rating      Float?    @default(0.0)
  isActive    Boolean   @default(true)
  
  // Relations
  bookings    ServiceBooking[]
  mechanics   Mechanic[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Mechanics and service staff
model Mechanic {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  specialties String   // JSON string of areas of expertise
  isActive    Boolean   @default(true)
  isOnDuty    Boolean   @default(false)
  
  // Relations
  garageId    String
  garage      Garage   @relation(fields: [garageId], references: [id])
  
  assignments ServiceAssignment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Service bookings
model ServiceBooking {
  id          String   @id @default(cuid())
  
  // Booking details
  serviceType String   // towing, mechanic, fuel, accident
  description String?
  urgency     String   @default("normal") // normal, urgent, emergency
  status      String   @default("pending") // pending, assigned, in_progress, completed, cancelled
  
  // Scheduling
  preferredDate DateTime?
  preferredTime  String?
  estimatedArrival String?
  
  // Location
  pickupAddress String
  latitude      Float
  longitude     Float
  
  // Relations
  vehicleId     String
  vehicle       Vehicle @relation(fields: [vehicleId], references: [id])
  userId        String
  user          User    @relation(fields: [userId], references: [id])
  garageId      String?
  garage        Garage? @relation(fields: [garageId], references: [id])
  
  // Assignment
  assignments   ServiceAssignment[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Service assignments to mechanics
model ServiceAssignment {
  id           String   @id @default(cuid())
  status       String   @default("assigned") // assigned, in_progress, completed
  
  // Relations
  bookingId    String
  booking      ServiceBooking @relation(fields: [bookingId], references: [id])
  mechanicId   String
  mechanic     Mechanic       @relation(fields: [mechanicId], references: [id])
  
  assignedAt   DateTime @default(now())
  completedAt  DateTime?
  notes        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Admin users
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  name      String
  role      String   @default("admin") // admin, supervisor, operator
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}